# ── База данных ───────────────────────────────────────────────────────────────
# Локально (docker compose): хост db; локальный запуск: localhost.
DATABASE_URL=postgresql+asyncpg://faberge:faberge@localhost:5432/faberge
# Yandex Managed PostgreSQL 17 (TLS обязателен — скачайте CA-сертификат):
#   DATABASE_URL=postgresql+asyncpg://<user>:<pwd>@<fqdn>:6432/<db>
#   DB_SSL_ROOT_CERT=/home/<user>/.postgresql/root.crt
# DB_SSL_ROOT_CERT=
SQL_ECHO=false

# ── Приложение ────────────────────────────────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=*
ADMIN_API_TOKEN=dev-admin-token
MEDIA_DIR=media
RECOGNITION_CONFIDENCE_THRESHOLD=0.6
MAX_UPLOAD_MB=10

# ── Yandex Cloud (опционально; без ключей сервисы работают в режиме-стабе) ─────
# YANDEX_API_KEY=
# YANDEX_FOLDER_ID=
# YANDEXGPT_MODEL_URI=gpt://<folder-id>/yandexgpt/latest
# YOLO_ENDPOINT=https://<your-yolo-endpoint>/recognize
# SPEECHKIT_API_KEY=
# OBJECT_STORAGE_BUCKET=faberge-media
# OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net
# OBJECT_STORAGE_PUBLIC_BASE=https://cdn.example.cloud
# AWS_ACCESS_KEY_ID=          # статический ключ сервисного аккаунта (для Object Storage)
# AWS_SECRET_ACCESS_KEY=
